# ============================================================
# BI 工具箱 - 环境变量配置模板
# 
# 使用方式:
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 修改 .env 中的值为真实配置
#   3. .env 文件不会被提交到 Git
# ============================================================

# ==================== Django 配置 ====================
# Django Secret Key（必须修改！用于加密 session、CSRF 等）
# 生成方式: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-random-secret-key-change-me

# 调试模式（生产环境务必设为 False）
DEBUG=False

# 允许访问的域名/IP（逗号分隔）
ALLOWED_HOSTS=your-server-ip,your-domain.com

# ==================== 数据库配置（必须配置） ====================
# Docker 环境必须配置 MySQL，否则重启后数据会丢失！
# 如果不配置 DB_HOST，Docker 将使用 SQLite，重启后所有数据（用户、定时任务等）都会消失
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-database-name

# ==================== Redis 配置 ====================
# Redis 连接地址（Docker 内部网络自动使用 redis:6379）
REDIS_URL=redis://redis:6379/0

# ==================== Celery 配置 ====================
# Celery Worker 并行数
CELERY_CONCURRENCY=4

# ==================== Nginx 配置 ====================
# Web 服务端口（Docker 映射）
WEB_PORT=8000

# Nginx 端口
NGINX_PORT=80

# ==================== 通知配置（可选） ====================
# 钉钉机器人 Webhook
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 企业微信机器人 Webhook
WECOM_WEBHOOK=

# 邮件通知渠道
NOTIFY_CHANNEL=dingtalk
# ============================================================
# BI 工具箱 - 环境变量配置模板
# 
# 使用方式:
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 修改 .env 中的值为真实配置
#   3. .env 文件不会被提交到 Git
# ============================================================

# ==================== Django 配置 ====================
# Django Secret Key（必须修改！用于加密 session、CSRF 等）
# 生成方式: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-random-secret-key-change-me

# 调试模式（生产环境务必设为 False）
DEBUG=True

# 允许访问的域名/IP（逗号分隔）
ALLOWED_HOSTS=127.0.0.1,localhost

# ==================== 数据库配置 ====================
# Django 内部数据库（用户、定时任务等）默认使用 SQLite
# 如需使用 MySQL，请配置以下选项
DB_PATH=db.sqlite3
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password
# DB_NAME=your-database-name

# ==================== Redis 配置 ====================
# Redis 连接地址（用于 Celery 定时任务）
REDIS_URL=redis://localhost:6379/0

# ==================== 通知配置（可选） ====================
# 钉钉机器人 Webhook
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 企业微信机器人 Webhook
WECOM_WEBHOOK=

# 通知渠道: dingtalk / wecom
NOTIFY_CHANNEL=dingtalk